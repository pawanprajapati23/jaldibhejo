{
  "name": "JaldiBhejo",
  "short_name": "JaldiBhejo",
  "description": "Fast WebRTC peer-to-peer file sharing and free online tools.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#3B82F6",
  "icons": [
    {
      "src": "/favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
      "type": "image/x-icon"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["*/*"]
        }
      ]
    }
  }
}
